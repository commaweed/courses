[user]
	name = xxxx 
	email = xxxxxx@xxxxx
[push]
	#default = tracking
    default = simple
[core]
	editor = vim
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
	ignorecase = false
	precomposeunicode = false
    autocrlf = input
[alias]
   #oldll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate
   #ll = log --graph --oneline --color --pretty=format:'%C(yellow)%h%d%C(reset) %s %C(cyan)[%an, %ar]%C(reset)'
   #ch=log --name-status --oneline --pretty=format:'%C(yellow)%h%d%C(reset) %s
   	lt = log --tags --color --pretty=format:'%C(yellow)%h%C(reset) %C(red)%d%C(reset) %s %C(cyan)[%an, %ar]%C(reset)' --decorate=full 
	ch = log --name-status --oneline --color --pretty=format:'%C(yellow)%h%C(reset) %C(red)%d%C(reset) %s %C(cyan)[%an, %ar]%C(reset)'
   	all = log --oneline --color --pretty=format:'%C(yellow)%h%C(reset) %C(red)%d%C(reset) %s %C(cyan)[%an, %ar]%C(reset)' --decorate=full
	gr = log --graph --oneline --color --pretty=format:'%C(yellow)%h%C(reset) %C(red)%d%C(reset) %s %C(cyan)[%an, %ar]%C(reset)' --full-history --all
	lll = log --oneline --color --date=short --pretty=format:'%C(yellow)%h%C(reset)%x09%C(cyan)%ad%C(reset)%x09<(32)%C(cyan)%an%C(reset)%x09<(75,trunc)%s%x09<(40,trunc)%C(red)%d%C(reset)%x09(describe:tags=true)'
	me = whatchaged --author="tjjenk2" --name-status --oneline --pretty=format:'%C(yellow)%h%C(reset) %C(red)%d%C(reset) %s %C(cyan)[%an, %ar]%C(reset)'
	review = merge --no-commit --no-ff -Xignore-space-change
	sort = for-each-ref --sort=commiterdate refs/heads/ --format='$(committerdate:short) %(refname:short)'
	sortr = for-each-ref --sort=commiterdate refs/remotes/ --format='$(committerdate:short) %(refname:short)'
	branchltor = for-each-ref --format='$(refname:short) %(upstream:short)' refs/heads
[credential]
	helper = cache --timeout 7200
